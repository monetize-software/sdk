{
  "manifest_version": 3,
  "name": "Monetize SDK — Demo Extension",
  "version": "0.1.0",
  "description": "Reference extension showing offscreen-backed paywall integration. Wire this up against your own paywallId/apiOrigin.",
  "permissions": ["offscreen", "storage", "identity"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "sw.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Monetize Demo"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
